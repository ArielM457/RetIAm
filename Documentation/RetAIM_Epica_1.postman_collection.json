    {
      "name": "Epica 7 - Exams",
      "item": [
        {
          "name": "Iniciar examen final",
          "request": {
            "method": "POST",
            "description": "Prerequisito real del backend: el plan debe tener todas sus secciones completadas. Si no, este endpoint responde 409.",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{employeeToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"plan_id\": \"{{planId}}\",\n  \"time_limit_minutes\": 60\n}"
            },
            "url": "{{baseUrl}}/exams/final"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code < 300) {",
                  "  var json = pm.response.json();",
                  "  if (json && json.id) pm.collectionVariables.set('attemptId', json.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Enviar examen final aprobado para AZ-900",
          "request": {
            "method": "POST",
            "description": "Este body esta alineado al patron de preguntas del track por defecto AZ-900. Si cambias la certificacion objetivo, ajusta las respuestas segun el intento generado.",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{employeeToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"answers\": [\n    { \"question_id\": \"exam-1\", \"selected_option_index\": 0 },\n    { \"question_id\": \"exam-2\", \"selected_option_index\": 1 },\n    { \"question_id\": \"exam-3\", \"selected_option_index\": 2 },\n    { \"question_id\": \"exam-4\", \"selected_option_index\": 3 },\n    { \"question_id\": \"exam-5\", \"selected_option_index\": 0 },\n    { \"question_id\": \"exam-6\", \"selected_option_index\": 1 },\n    { \"question_id\": \"exam-7\", \"selected_option_index\": 2 },\n    { \"question_id\": \"exam-8\", \"selected_option_index\": 3 },\n    { \"question_id\": \"exam-9\", \"selected_option_index\": 0 },\n    { \"question_id\": \"exam-10\", \"selected_option_index\": 0 },\n    { \"question_id\": \"exam-11\", \"selected_option_index\": 1 },\n    { \"question_id\": \"exam-12\", \"selected_option_index\": 2 },\n    { \"question_id\": \"exam-13\", \"selected_option_index\": 3 },\n    { \"question_id\": \"exam-14\", \"selected_option_index\": 0 },\n    { \"question_id\": \"exam-15\", \"selected_option_index\": 1 }\n  ]\n}"
            },
            "url": "{{baseUrl}}/exams/final/{{attemptId}}/submit"
          }
        },
        {
          "name": "Listar mis certificados",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (Array.isArray(json) && json.length > 0 && json[0].id) pm.collectionVariables.set('certificateId', json[0].id);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{employeeToken}}"
              }
            ],
            "url": "{{baseUrl}}/exams/certificates/mine"
          }
        }
      ]
    },
